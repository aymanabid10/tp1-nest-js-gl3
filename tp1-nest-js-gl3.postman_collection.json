{
  "info": {
    "_postman_id": "8b51239c-b171-4770-bc22-ca6a4b1bb095",
    "name": "NestJS Full Messaging System (User1 & User2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
