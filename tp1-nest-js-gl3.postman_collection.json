  "item": [
    {
      "name": "1. User 1 Auth",
      "item": [
        {
          "name": "1.1 Sign Up (User 1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"user1\",\n    \"email\": \"user1@test.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "1.2 Sign In (Saves jwt_token_1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"jwt_token_1\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@test.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/signin",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "signin"]
            }
          }
        }
